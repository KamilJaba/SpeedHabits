// .devcontainer/devcontainer.json
{
  "name": "Expo React Native",
  "image": "mcr.microsoft.com/devcontainers/javascript-node:1-20-bullseye",
  "features": {},

  "forwardPorts": [8081, 19000, 19001, 19002],

  "remoteEnv": {
    "REACT_NATIVE_PACKAGER_HOSTNAME": "${localEnv:LOCAL_LAN_IP}",
    "EXPO_DEVTOOLS_LISTEN_ADDRESS": "0.0.0.0",
    "NPX_EXPO_USERNAME": "${localEnv:NPX_EXPO_USERNAME}",
    "NPX_EXPO_PASSWORD": "${localEnv:NPX_EXPO_PASSWORD}"
  },

  "postCreateCommand": "sudo apt-get update && sudo apt-get install -y watchman && npm install -g @expo/cli eas-cli && cd Speedhabits && npm install",

  "customizations": {
    "vscode": {
      "extensions": ["ms-vscode.vscode-typescript-next", "esbenp.prettier-vscode", "bradlc.vscode-tailwindcss"]
    }
  }
}
